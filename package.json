{
  "name": "@igorjs/pure-fx",
  "version": "0.1.0",
  "description": "Pure FX: functional application framework for TypeScript. Result, Option, Task, Stream, immutable Record/List, Schema, Codec, Lens, Retry, CircuitBreaker, HTTP Server. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js"
    },
    "./async": {
      "types": "./dist/async/index.d.ts",
      "import": "./dist/async/index.js"
    },
    "./io": {
      "types": "./dist/io/index.d.ts",
      "import": "./dist/io/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./runtime/adapter/node": {
      "types": "./dist/runtime/adapter/node.d.ts",
      "import": "./dist/runtime/adapter/node.js"
    },
    "./runtime/adapter/lambda": {
      "types": "./dist/runtime/adapter/lambda.d.ts",
      "import": "./dist/runtime/adapter/lambda.js"
    },
    "./runtime/adapter/deno": {
      "types": "./dist/runtime/adapter/deno.d.ts",
      "import": "./dist/runtime/adapter/deno.js"
    },
    "./runtime/adapter/bun": {
      "types": "./dist/runtime/adapter/bun.d.ts",
      "import": "./dist/runtime/adapter/bun.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "build": "node scripts/build.mjs",
    "test": "pure-test tests/",
    "test:types": "tsgo -p tsconfig.test.json",
    "test:ci": "node scripts/test-ci.mjs",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "node scripts/prepublish.mjs"
  },
  "keywords": [
    "functional",
    "typescript",
    "immutable",
    "result",
    "option",
    "monad",
    "task",
    "stream",
    "lens",
    "optics",
    "schema",
    "codec",
    "validation",
    "retry",
    "circuit-breaker",
    "pipe",
    "flow",
    "pattern-matching",
    "http",
    "server",
    "middleware",
    "zero-dependency",
    "type-safe",
    "deep-freeze",
    "record",
    "list",
    "lazy",
    "nominal-types",
    "cron",
    "duration",
    "ts7"
  ],
  "author": "igorjs <oss@mail.igorjs.io>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igorjs/pure-fx.git"
  },
  "bugs": {
    "url": "https://github.com/igorjs/pure-fx/issues"
  },
  "homepage": "https://github.com/igorjs/pure-fx#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/igorjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@igorjs/pure-test": "^0.1.0",
    "@typescript/native-preview": "latest",
    "miniflare": "^4.20260430.0",
    "playwright": "^1.59.1"
  },
  "peerDependencies": {
    "typescript": ">=5.7.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
