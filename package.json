{
  "name": "@igorjs/pure-ts",
  "version": "0.2.5",
  "description": "Pure TS: functional application framework for TypeScript. Result, Option, Task, Stream, immutable Record/List, Schema, Codec, Lens, Retry, CircuitBreaker, HTTP Server. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime/adapter/node": {
      "types": "./dist/runtime/adapter/node.d.ts",
      "import": "./dist/runtime/adapter/node.js"
    },
    "./runtime/adapter/lambda": {
      "types": "./dist/runtime/adapter/lambda.d.ts",
      "import": "./dist/runtime/adapter/lambda.js"
    },
    "./runtime/adapter/deno": {
      "types": "./dist/runtime/adapter/deno.d.ts",
      "import": "./dist/runtime/adapter/deno.js"
    },
    "./runtime/adapter/bun": {
      "types": "./dist/runtime/adapter/bun.d.ts",
      "import": "./dist/runtime/adapter/bun.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "build": "rm -rf dist && tsgo && node scripts/strip-dist-comments.mjs",
    "test": "node --test tests/runtime.test.js tests/integration.test.js tests/program.test.js tests/server.test.js tests/core-new.test.js tests/async-new.test.js tests/data-new.test.js",
    "test:types": "tsgo -p tsconfig.test.json",
    "version": "node scripts/sync-pkg-version.mjs && git add jsr.json",
    "prepublishOnly": "pnpm run lint && pnpm run check && pnpm run build && pnpm test && pnpm run test:types"
  },
  "keywords": [
    "functional",
    "typescript",
    "immutable",
    "result",
    "option",
    "monad",
    "task",
    "stream",
    "lens",
    "optics",
    "schema",
    "codec",
    "validation",
    "retry",
    "circuit-breaker",
    "pipe",
    "flow",
    "pattern-matching",
    "http",
    "server",
    "middleware",
    "zero-dependency",
    "type-safe",
    "deep-freeze",
    "record",
    "list",
    "lazy",
    "nominal-types",
    "cron",
    "duration",
    "ts7"
  ],
  "author": "igorjs <oss@mail.igorjs.io>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igorjs/pure-ts.git"
  },
  "bugs": {
    "url": "https://github.com/igorjs/pure-ts/issues"
  },
  "homepage": "https://github.com/igorjs/pure-ts#readme",
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@typescript/native-preview": "latest"
  },
  "peerDependencies": {
    "typescript": ">=5.5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
